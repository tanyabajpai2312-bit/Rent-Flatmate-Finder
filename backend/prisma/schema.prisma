// Prisma schema for Rent & Flatmate Finder
// Uses SQLite by default for zero-config local/dev + easy deploy on Render/Railway.
// Swap provider to "postgresql" and set DATABASE_URL to a Postgres URL for production scale.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}





model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String
  createdAt    DateTime @default(now())

  listings        Listing[]        @relation("OwnerListings")
  tenantProfile   TenantProfile?
  interestsSent   Interest[]       @relation("TenantInterests")
  messagesSent    Message[]        @relation("SentMessages")
}

model TenantProfile {
  id               String   @id @default(cuid())
  user             User     @relation(fields: [userId], references: [id])
  userId           String   @unique
  preferredLocation String
  budgetMin        Int
  budgetMax        Int
  moveInDate       DateTime
  createdAt        DateTime @default(now())
}

model Listing {
  id                String           @id @default(cuid())
  owner             User             @relation("OwnerListings", fields: [ownerId], references: [id])
  ownerId           String
  location          String
  rent              Int
  availableFrom     DateTime
  roomType          String
  furnishingStatus  String
  photos            String           // comma-separated URLs (or JSON string array)
  isFilled          Boolean          @default(false)
  createdAt         DateTime         @default(now())

  interests         Interest[]
  scores            CompatibilityScore[]
}

model CompatibilityScore {
  id            String   @id @default(cuid())
  listing       Listing  @relation(fields: [listingId], references: [id])
  listingId     String
  tenantId      String
  score         Int
  explanation   String
  source        String   // "llm" or "rule-based-fallback"
  createdAt     DateTime @default(now())

  @@unique([listingId, tenantId])
}

model Interest {
  id          String         @id @default(cuid())
  tenant      User           @relation("TenantInterests", fields: [tenantId], references: [id])
  tenantId    String
  listing     Listing        @relation(fields: [listingId], references: [id])
  listingId   String
  status      String @default("PENDING")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  messages    Message[]

  @@unique([tenantId, listingId])
}

model Message {
  id          String   @id @default(cuid())
  interest    Interest @relation(fields: [interestId], references: [id])
  interestId  String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  senderId    String
  content     String
  createdAt   DateTime @default(now())
}
